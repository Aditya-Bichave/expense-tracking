# Copy this to .env and fill in the values.
# NEVER commit .env — it is .gitignored.

# Supabase project settings (same as your production project)
E2E_SUPABASE_URL=https://your-project.supabase.co
E2E_SUPABASE_ANON_KEY=your-anon-key

# Dedicated E2E test user (email+password, created in Supabase Auth > Users)
# No magic link / OTP needed — no email credits consumed.
E2E_TEST_EMAIL=e2e-test-email
E2E_TEST_PASSWORD=e2e-test-password

# URL of the locally-served Flutter web build
APP_BASE_URL=http://localhost:8080

# Path to the built web app (relative to ci/e2e)
BUILD_DIR=../../build/web
